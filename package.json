{
  "name": "arush-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Personal portfolio website for Arush Mishra",
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint script.js portfolio.config.js",
    "lint:css": "stylelint style.css",
    "lint:html": "html-validate index.html",
    "format": "prettier --write \"*.{html,css,js,json,yml}\"",
    "format:check": "prettier --check \"*.{html,css,js,json,yml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "html-validate": "^9.3.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0"
  }
}
